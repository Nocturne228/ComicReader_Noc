<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Nocturne Manga</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'%3E%3Crect width='24' height='24' rx='4' fill='%234285f4'/%3E%3Ctext x='12' y='17' text-anchor='middle' font-size='14' font-family='sans-serif' fill='white'%3EP%3C/text%3E%3C/svg%3E">
<link rel="stylesheet" href="{{ css_path }}">
{% if base_url %}<meta name="base-url" content="{{ base_url }}">{% endif %}
<script>
window.CATALOG_CONFIG = {{ catalog_config|tojson }};
</script>
<script src="{{ js_path }}" defer></script>
</head>
<body>
<div class="layout">
    <button class="sidebar-expand-btn" id="sidebarToggle" title="展开目录">☰</button>
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div>
                <h1>Nocturne Manga</h1>
                <div class="count" id="sidebarCount">{{ total_count }} 本</div>
            </div>
            <button class="sidebar-collapse-btn" id="sidebarCollapse" title="收起目录">◀</button>
        </div>
        <div class="sidebar-search">
            <input type="text" placeholder="搜索..." id="searchInput">
        </div>
        <div class="sidebar-tree" id="sidebarTree"></div>
        <div class="sidebar-resizer" id="sidebarResizer" role="separator" aria-orientation="vertical" title="拖拽调整侧边栏宽度"></div>
    </aside>

    <main class="main">
        <header class="catalog-top">
            <div class="catalog-heading">
                <div class="catalog-kicker">Local PDF Library</div>
                <h2>Nocturne Manga</h2>
                <div class="catalog-summary">{{ total_count }} 本漫画 · 双页阅读</div>
            </div>
            <div class="toolbar">
                <span class="toolbar-group">
                <select id="sortSelect" title="排序">
                    <option value="name">按名称排序</option>
                    <option value="time">按修改时间排序</option>
                </select>
                <button class="btn-sm" id="toggleFoldBtn" title="展开或折叠全部目录">全部折叠</button>
{% if catalog_config.nativeOpenEnabled %}
                <button class="btn-sm" id="toggleViewModeBtn" title="切换 PDF 打开方式">网页阅读</button>
{% endif %}
                </span>
{% if base_url %}
                <span class="toolbar-sep"></span>
                <span class="tool-btn-group">
                    <button class="btn-sm tool-btn" data-tool="x" title="批量统一 PDF 页面尺寸（备份到 x_backup）">PDF 缩放</button>
                    <button class="btn-sm tool-btn" data-tool="y" title="批量删除 PDF 指定页面（备份到 y_backup）">PDF 裁剪</button>
                    <button class="btn-sm tool-btn" data-tool="z" title="将 ZIP 压缩包批量转为 PDF">ZIP 转 PDF</button>
                </span>
                <span class="toolbar-sep"></span>
                <span class="toolbar-group">
                <button class="btn-sm" id="openRootBtn" title="在文件管理器中打开漫画根目录">📂 根目录</button>
                <button class="btn-sm" id="refreshCatalogBtn" title="重新扫描 PDF 目录">刷新目录</button>
                <button class="btn-sm muted" id="clearCacheBtn" title="清除阅读器缓存">重置阅读</button>
                <button class="btn-sm danger" id="shutdownServerBtn" title="关闭本地 HTTP 服务">关闭服务</button>
                <button class="btn-sm muted" id="restartServerBtn" title="重启服务以应用更新（debug）">重启服务</button>
                </span>
{% else %}
                <button class="btn-sm muted" id="clearCacheBtn" title="清除阅读器缓存">重置阅读</button>
{% endif %}
                <button class="btn-sm icon-btn" id="shortcutHelpBtn" type="button" aria-label="查看快捷键" title="查看快捷键">?</button>
            </div>
        </header>
{% if base_url %}
        <div class="service-url">服务地址: <code>{{ base_url }}</code></div>
{% endif %}
        <div class="grid" id="grid">
{% for group in folder_groups %}
            <section class="folder-group" data-folder="{{ group.folder }}">
                <button class="folder-header collapsed" type="button" data-folder="{{ group.folder }}">
                    <span class="fold-arrow">▼</span>
                    <span class="folder-icon">📂</span>
                    <span class="folder-label">{{ group.label }}</span>
                </button>
                <div class="folder-grid">
{% for item in group.cards %}
                    <article class="card" id="card-{{ item.index }}" data-index="{{ item.index }}" data-title="{{ item.title|lower }}" data-mtime="{{ item.mtime }}" data-pdf="{{ item.pdf_rel }}" data-folder="{{ group.folder }}">
                        <button class="card-cover" type="button" title="阅读 {{ item.title }}">
                            <img src="{{ item.image }}" loading="lazy" alt="{{ item.title }}">
                            <span class="card-hover">
                                <span class="card-hover-inner" aria-hidden="true">
                                    <svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                </span>
                            </span>
                        </button>
                        <div class="card-body">
                            <div class="card-title">{{ item.title }}</div>
                            <div class="card-meta">{{ item.size }} · {{ item.mtime_text }}</div>
                        </div>
                    </article>
{% endfor %}
                </div>
            </section>
{% endfor %}
        </div>
    </main>
</div>

<button id="reader-exit">← 返回目录</button>

<div id="progress-overlay" aria-live="polite">
    <div id="progress-box">
        <h3 id="progress-title">正在解析 PDF...</h3>
        <div class="progress-bar"><div class="progress-fill" id="progress-fill"></div></div>
        <p id="progress-text">准备中...</p>
        <p id="progress-error"></p>
        <p id="progress-note"></p>
        <div class="progress-actions">
            <button type="button" id="progressCancel">关闭</button>
            <button type="button" id="progressClose">关闭</button>
        </div>
    </div>
</div>
<!-- 文件管理工具对话框 -->
<div class="tool-dialog" id="toolDialog" style="display:none">
    <div class="tool-dialog-backdrop" id="toolDialogBackdrop"></div>
    <div class="tool-dialog-panel">
        <div class="tool-dialog-header">
            <h3 id="toolDialogTitle">工具名称</h3>
            <p class="tool-dialog-desc" id="toolDialogDesc">工具描述</p>
        </div>
        <div class="tool-dialog-body">
            <div class="form-row">
                <label>目标目录 <span class="form-note">（相对于 PDF 根目录）</span></label>
                <select class="form-select" id="toolFolderSelect"></select>
            </div>
            <div class="form-section-label">参数设置</div>
            <div id="toolParamsForm">
                <!-- 动态加载参数表单 -->
            </div>
        </div>
        <div class="tool-output-wrap" id="toolOutputWrap">
            <div class="tool-output-header">
                <span>脚本输出</span>
                <button type="button" class="tool-output-copy" id="toolOutputCopy" title="复制到剪贴板">复制</button>
            </div>
            <pre class="tool-output" id="toolResultOutput"></pre>
        </div>
        <div class="tool-dialog-footer">
            <button type="button" class="btn-sm" id="toolDialogOpen" title="在文件管理器中打开目标目录">打开目录</button>
            <button type="button" class="btn-sm muted" id="toolDialogClean" title="清理本工具的备份/转换产物">清理</button>
            <span style="flex:1"></span>
            <button type="button" class="btn-sm" id="toolDialogCancel">关闭</button>
            <button type="button" class="btn-sm btn-primary" id="toolDialogRun">执行</button>
        </div>
    </div>
</div>

<!-- 快捷键帮助页（全屏弹窗） -->
<div class="shortcut-help" id="shortcutHelp" style="display:none">
    <div class="shortcut-help-backdrop"></div>
    <div class="shortcut-help-page">
        <div class="shortcut-help-card">
            <div class="shortcut-help-head">
                <h2>⌨ 快捷键</h2>
                <button type="button" class="shortcut-help-close" id="shortcutHelpClose" title="关闭">✕</button>
            </div>
            <div class="shortcut-help-body">
                <p class="shortcut-help-sub">在页面任意位置按对应键即可触发</p>

                <div class="shortcut-group">
                    <div class="shortcut-group-title">通用</div>
                    <div class="shortcut-row"><span class="shortcut-row-label">显示 / 隐藏帮助</span><kbd>?</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">聚焦搜索框</span><kbd>/</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">收起 / 展开侧边栏</span><kbd>B</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">展开 / 折叠全部目录</span><kbd>f</kbd></div>
{% if catalog_config.nativeOpenEnabled %}
                    <div class="shortcut-row"><span class="shortcut-row-label">切换网页阅读 / Preview</span><kbd>V</kbd></div>
{% endif %}
                    <div class="shortcut-row"><span class="shortcut-row-label">重置阅读设置</span><kbd>C</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">关闭对话框 / 帮助</span><kbd>Esc</kbd></div>
                </div>

{% if base_url %}
                <div class="shortcut-group">
                    <div class="shortcut-group-title">文件工具</div>
                    <div class="shortcut-row"><span class="shortcut-row-label">PDF 缩放工具</span><kbd>X</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">PDF 裁剪工具</span><kbd>Y</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">ZIP→PDF 工具</span><kbd>Z</kbd></div>
                    <div class="shortcut-row"><span class="shortcut-row-label">刷新目录</span><kbd>R</kbd></div>
                </div>
{% endif %}

                <p class="shortcut-help-tip">再次按 <kbd>?</kbd> / <kbd>Esc</kbd> / 点击背景 / <kbd>✕</kbd> 关闭</p>
            </div>
        </div>
    </div>
</div>

</body>
</html>
